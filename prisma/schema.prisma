generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  OPERATOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum LogAction {
  CREATE
  UPDATE
  DELETE
  PURGE_CACHE
}

enum LogStatus {
  SUCCESS
  FAILURE
}

enum CacheScope {
  EVERYTHING
  CUSTOM
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      Role     @default(OPERATOR)
  password  String
  refreshToken String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  status    UserStatus @default(ACTIVE)
  logs      Log[]
  tokens    Token[]
}



model Token {
  id        String   @id @default(uuid())
  userId    String
  token     String   
  expiresAt DateTime

  
  user      User     @relation(fields: [userId], references: [id])
}

model Log {
  id        String   @id @default(uuid())
  userId    String
  type      LogAction
  zone      String
  recordName  String
  status    LogStatus @default(FAILURE)
  message   String[] @default([]) 
  cacheScope CacheScope?

  before    Json?   
  after     Json?   

  timestamp DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id])
}

